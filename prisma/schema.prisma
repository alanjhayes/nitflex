generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  watchlist     Watchlist[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model StreamCache {
  id        String   @id @default(cuid())
  tmdbId    Int
  mediaType String
  season    Int?
  episode   Int?
  m3u8Url   String
  referer   String
  cachedAt  DateTime @default(now())

  @@unique([tmdbId, mediaType, season, episode])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  tmdbId    Int
  mediaType String
  title     String
  poster    String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, tmdbId, mediaType])
}
